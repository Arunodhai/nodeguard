{
  "name": "nodeguard",
  "version": "0.1.0",
  "description": "Scan Node.js dependencies for vulnerabilities and auto-create GitHub PRs with fixes",
  "type": "module",
  "bin": {
    "nodeguard": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js serve",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "@octokit/rest": "^21.1.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "fastify": "^5.8.2",
    "ora": "^8.2.0",
    "prom-client": "^15.1.3",
    "semver": "^7.7.1"
  },
  "devDependencies": {
    "@types/semver": "^7.5.8",
    "@vitest/coverage-v8": "^3.2.4",
    "msw": "^2.7.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
